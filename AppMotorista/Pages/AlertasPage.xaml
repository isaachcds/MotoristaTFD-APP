<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.AlertasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:AlertasViewModel"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!--  CONTEÚDO PRINCIPAL  -->
        <Grid RowDefinitions="Auto,*,Auto">

            <!--  TOPO  -->
            <Grid
                Grid.Row="0"
                Padding="8,0,12,0"
                BackgroundColor="White"
                ColumnDefinitions="40,*"
                HeightRequest="48">

                <ImageButton
                    Grid.Column="0"
                    Padding="4"
                    BackgroundColor="Transparent"
                    Command="{Binding AlternarMenuCommand}"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    Source="menuhamburguer_icon.svg"
                    VerticalOptions="Center"
                    WidthRequest="24" />

                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="14"
                    HorizontalTextAlignment="Start"
                    Text="{Binding TituloPagina}"
                    TextColor="#2357C6"
                    VerticalTextAlignment="Center" />
            </Grid>

            <!--  CONTEÚDO  -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="14,12,14,24" Spacing="16">

                    <!--  BOTÃO REGISTRAR  -->
                    <dx:DXButton
                        BackgroundColor="#2357C6"
                        ButtonType="Accent"
                        Command="{Binding NovaOcorrenciaCommand}"
                        Content="REGISTRAR NOVA OCORRÊNCIA"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="11"
                        HeightRequest="48"
                        Icon="plus_icon.svg"
                        TextColor="White" />

                    <!--  ALERTAS ATIVOS  -->
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="16"
                                Text="Alertas Ativos"
                                TextColor="#111827"
                                VerticalTextAlignment="Center" />

                            <Border
                                Grid.Column="1"
                                Padding="8,3"
                                BackgroundColor="#D32F2F"
                                HorizontalOptions="End"
                                StrokeThickness="0"
                                VerticalOptions="Center">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="8"
                                    Text="URGENTE"
                                    TextColor="White" />
                            </Border>
                        </Grid>

                        <CollectionView ItemsSource="{Binding AlertasAtivos}" SelectionMode="None">

                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="12" Orientation="Vertical" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:AlertaItem">

                                    <Border
                                        Padding="14"
                                        BackgroundColor="White"
                                        StrokeThickness="0">

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirItemCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>

                                        <Border.Shadow>
                                            <Shadow
                                                Brush="#15000000"
                                                Opacity="0.16"
                                                Radius="10"
                                                Offset="0,4" />
                                        </Border.Shadow>

                                        <Grid ColumnDefinitions="30,*" ColumnSpacing="10">

                                            <Border
                                                Grid.Column="0"
                                                BackgroundColor="#FFF0F0"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                VerticalOptions="Start"
                                                WidthRequest="26">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="13" />
                                                </Border.StrokeShape>

                                                <Label
                                                    FontSize="14"
                                                    HorizontalTextAlignment="Center"
                                                    Text="⚠"
                                                    TextColor="#D32F2F"
                                                    VerticalTextAlignment="Center" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    IsVisible="{Binding ExibirTitulo}"
                                                    Text="{Binding Titulo}"
                                                    TextColor="#111827" />

                                                <Label
                                                    FontSize="12"
                                                    LineBreakMode="WordWrap"
                                                    Text="{Binding Descricao}"
                                                    TextColor="#4B5563" />
                                            </VerticalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!--  OCORRÊNCIAS RECENTES  -->
                    <VerticalStackLayout Spacing="10">

                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Ocorrências Recentes"
                            TextColor="#111827" />

                        <CollectionView ItemsSource="{Binding OcorrenciasRecentes}" SelectionMode="None">

                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="12" Orientation="Vertical" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:AlertaItem">

                                    <Border
                                        Padding="14"
                                        BackgroundColor="White"
                                        StrokeThickness="0">

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirItemCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>

                                        <Border.Shadow>
                                            <Shadow
                                                Brush="#15000000"
                                                Opacity="0.16"
                                                Radius="10"
                                                Offset="0,4" />
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="30,*,Auto" ColumnSpacing="10">

                                                <Border
                                                    Grid.Column="0"
                                                    BackgroundColor="#EEF3FF"
                                                    HeightRequest="26"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Start"
                                                    WidthRequest="26">

                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="13" />
                                                    </Border.StrokeShape>

                                                    <Label
                                                        FontSize="14"
                                                        HorizontalTextAlignment="Center"
                                                        Text="{Binding IconeTexto}"
                                                        TextColor="#2357C6"
                                                        VerticalTextAlignment="Center" />
                                                </Border>

                                                <Label
                                                    Grid.Column="1"
                                                    FontAttributes="Bold"
                                                    FontSize="13"
                                                    Text="{Binding Titulo}"
                                                    TextColor="#111827"
                                                    VerticalTextAlignment="Center" />

                                                <Border
                                                    Grid.Column="2"
                                                    Padding="8,3"
                                                    BackgroundColor="{Binding CorFundo}"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Start">

                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>

                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="8"
                                                        Text="{Binding Severidade}"
                                                        TextColor="{Binding CorTexto}" />
                                                </Border>
                                            </Grid>

                                            <HorizontalStackLayout Margin="30,0,0,0" Spacing="5">
                                                <Label
                                                    FontSize="10"
                                                    Text="◷"
                                                    TextColor="#8A93A3"
                                                    VerticalTextAlignment="Center" />

                                                <Label
                                                    FontSize="10"
                                                    Text="{Binding DataHora}"
                                                    TextColor="#8A93A3"
                                                    VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!--  BOTTOM NAV  -->
            <Border
                Grid.Row="2"
                Padding="8,8,8,10"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18,18,0,0" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow
                        Brush="#18000000"
                        Opacity="0.15"
                        Radius="10"
                        Offset="0,-3" />
                </Border.Shadow>

                <Grid ColumnDefinitions="*,*,*,*">

                    <!--  INÍCIO INATIVO  -->
                    <Border
                        Grid.Column="0"
                        BackgroundColor="Transparent"
                        HeightRequest="58"
                        StrokeThickness="0">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrInicioCommand}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="22"
                                Source="menunavbar_home_inativo_icon.svg"
                                WidthRequest="22" />

                            <Label
                                FontAttributes="Bold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Início"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Border>

                    <!--  VIAGENS INATIVO  -->
                    <Border
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        HeightRequest="58"
                        StrokeThickness="0">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrViagensCommand}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="22"
                                Source="menunavbar_viagens_inativo_icon.svg"
                                WidthRequest="22" />

                            <Label
                                FontAttributes="Bold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Viagens"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Border>

                    <!--  ALERTAS ATIVO  -->
                    <Border
                        Grid.Column="2"
                        BackgroundColor="#EEF3FF"
                        HeightRequest="58"
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        WidthRequest="70">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrAlertasCommand}" />
                        </Border.GestureRecognizers>

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="22"
                                Source="menunavbar_alertas_ativo_icon.svg"
                                WidthRequest="22" />

                            <Label
                                FontAttributes="Bold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Alertas"
                                TextColor="#2357C6" />
                        </VerticalStackLayout>
                    </Border>

                    <!--  SUPORTE INATIVO  -->
                    <Border
                        Grid.Column="3"
                        BackgroundColor="Transparent"
                        HeightRequest="58"
                        StrokeThickness="0">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrSuporteCommand}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="22"
                                Source="menunavbar_perfil_inativo_icon.svg"
                                WidthRequest="22" />

                            <Label
                                FontAttributes="Bold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Suporte"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </Border>

        </Grid>

        <!--  OVERLAY  -->
        <Border
            BackgroundColor="#66000000"
            IsVisible="{Binding MenuAberto}"
            StrokeThickness="0">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCommand}" />
            </Border.GestureRecognizers>
        </Border>

        <!--  MENU LATERAL  -->
        <Grid
            BackgroundColor="White"
            HorizontalOptions="Start"
            IsVisible="{Binding MenuAberto}"
            WidthRequest="272">

            <Grid RowDefinitions="Auto,*,Auto">

                <!--  PERFIL  -->
                <VerticalStackLayout
                    Grid.Row="0"
                    Padding="18,28,18,20"
                    Spacing="10">

                    <Border
                        BackgroundColor="#EAF1FF"
                        HeightRequest="52"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        WidthRequest="52">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="JS"
                            TextColor="#2357C6"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="{Binding NomeMotorista}"
                            TextColor="#111827" />

                        <Label
                            FontSize="10"
                            Text="{Binding IdMotorista}"
                            TextColor="#6B7280" />

                        <Border
                            Padding="6,2"
                            BackgroundColor="#EEF3FF"
                            HorizontalOptions="Start"
                            StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5" />
                            </Border.StrokeShape>

                            <Label
                                FontAttributes="Bold"
                                FontSize="8"
                                Text="MOTORISTA TFD"
                                TextColor="#2357C6" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  ITENS MENU  -->
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding ItensMenu}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SideMenuItem">

                            <Grid Padding="12,2">

                                <Border
                                    Padding="12,10"
                                    BackgroundColor="{Binding CorFundo}"
                                    StrokeThickness="0">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirItemMenuCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="22,*" ColumnSpacing="10">

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="16"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="16" />

                                        <Label
                                            Grid.Column="1"
                                            FontSize="11"
                                            Text="{Binding Titulo}"
                                            TextColor="{Binding CorTexto}"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--  SAIR  -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Padding="18,0,18,28"
                    Spacing="16">

                    <BoxView HeightRequest="1" Color="#F0F0F0" />

                    <Border BackgroundColor="Transparent" StrokeThickness="0">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SairCommand}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                            <Image
                                Grid.Column="0"
                                HeightRequest="16"
                                Source="power_icon.svg"
                                VerticalOptions="Center"
                                WidthRequest="16" />

                            <Label
                                Grid.Column="1"
                                FontSize="11"
                                Text="Sair"
                                TextColor="#E53935"
                                VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>