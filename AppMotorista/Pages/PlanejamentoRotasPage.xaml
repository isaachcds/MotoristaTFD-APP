<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.PlanejamentoRotasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:PlanejamentoRotasViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            ColumnDefinitions="48,*,48">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="24"
                Source="menuhamburguer_icon.svg"
                WidthRequest="24" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="22"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="14">

                <Border
                    Padding="14"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18">
                    <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="10">
                        <Image
                            HeightRequest="20"
                            Source="trip_icon.svg"
                            WidthRequest="20" />

                        <Label
                            Grid.Column="1"
                            FontSize="15"
                            Text="{Binding FiltroData}"
                            TextColor="#333333"
                            VerticalTextAlignment="Center" />

                        <Button
                            Grid.Column="2"
                            Command="{Binding NovaRotaCommand}"
                            BackgroundColor="#2357C6"
                            CornerRadius="12"
                            HeightRequest="36"
                            Text="+ Nova rota"
                            TextColor="White" />
                    </Grid>
                </Border>

                <CollectionView
                    ItemsSource="{Binding Rotas}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:RoutePlanningItem">
                            <Border
                                Padding="16"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20">

                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                FontSize="13"
                                                Text="{Binding Data}"
                                                TextColor="#777777" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="20"
                                                Text="{Binding Horario}"
                                                TextColor="#2357C6" />
                                        </VerticalStackLayout>

                                        <Border
                                            Grid.Column="1"
                                            Padding="10,4"
                                            BackgroundColor="#EEF1FF"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                Text="{Binding Status}"
                                                TextColor="#4D6EF3" />
                                        </Border>
                                    </Grid>

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        Text="{Binding Destino}"
                                        TextColor="#1B1B1B" />

                                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                                        <Image
                                            HeightRequest="16"
                                            Source="fleet_icon.svg"
                                            WidthRequest="16" />
                                        <Label
                                            Grid.Column="1"
                                            FontSize="14"
                                            Text="{Binding Veiculo}"
                                            TextColor="#666666" />
                                    </Grid>

                                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                                        <Image
                                            HeightRequest="16"
                                            Source="tasklist_icon.svg"
                                            WidthRequest="16" />
                                        <Label
                                            Grid.Column="1"
                                            FontSize="14"
                                            Text="{Binding QuantidadePacientes}"
                                            TextColor="#666666" />
                                    </Grid>

                                    <Button
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PlanejamentoRotasViewModel}}, Path=AbrirRotaCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F3F5FB"
                                        CornerRadius="14"
                                        HeightRequest="42"
                                        Text="Abrir rota"
                                        TextColor="#2357C6" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>