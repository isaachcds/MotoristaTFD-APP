<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:HomePageViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid RowDefinitions="Auto,*,Auto">

            <!--  TOPO  -->
            <Grid
                Grid.Row="0"
                Padding="18,24,18,18"
                BackgroundColor="#2357C6"
                RowDefinitions="Auto,Auto">

                <Grid ColumnDefinitions="48,*,48">
                    <ImageButton
                        Grid.Column="0"
                        BackgroundColor="Transparent"
                        Command="{Binding AlternarMenuCommand}"
                        HeightRequest="26"
                        Source="menuhamburguer_icon.svg"
                        WidthRequest="26" />

                    <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        FontSize="24"
                        HorizontalTextAlignment="Center"
                        Text="Motorista"
                        TextColor="White"
                        VerticalTextAlignment="Center" />

                    <ImageButton
                        Grid.Column="2"
                        BackgroundColor="Transparent"
                        Command="{Binding AbrirQrCodeCommand}"
                        HeightRequest="24"
                        Source="qrcode_icon.svg"
                        WidthRequest="24" />
                </Grid>

                <VerticalStackLayout
                    Grid.Row="1"
                    Margin="0,14,0,0"
                    Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontSize="17"
                        Text="Resumo do dia"
                        TextColor="White" />
                    <Label
                        FontSize="13"
                        Text="{Binding ResumoDia}"
                        TextColor="#DCE6FF" />
                </VerticalStackLayout>
            </Grid>

            <!--  CONTEÚDO  -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                    <!--  VIAGENS DO DIA  -->
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Viagens do dia"
                                TextColor="#1B1B1B" />

                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="Deslize para ver mais"
                                TextColor="#7A7A7A"
                                VerticalTextAlignment="End" />
                        </Grid>

                        <CollectionView
                            HeightRequest="250"
                            ItemsSource="{Binding ViagensDoDia}"
                            SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="14" Orientation="Horizontal" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TripSummaryItem">
                                    <Border
                                        Padding="18"
                                        BackgroundColor="White"
                                        StrokeShape="RoundRectangle 22"
                                        StrokeThickness="0"
                                        WidthRequest="300">

                                        <VerticalStackLayout Spacing="14">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="18"
                                                Text="{Binding Titulo}"
                                                TextColor="#1B1B1B" />

                                            <Grid ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label
                                                        FontSize="13"
                                                        Text="{Binding Data}"
                                                        TextColor="#777777" />

                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="26"
                                                        Text="{Binding Horario}"
                                                        TextColor="#2357C6" />
                                                </VerticalStackLayout>

                                                <Border
                                                    Grid.Column="1"
                                                    Padding="10,5"
                                                    BackgroundColor="#E8F6EC"
                                                    StrokeShape="RoundRectangle 12"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Start">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="12"
                                                        Text="{Binding Status}"
                                                        TextColor="#239B56" />
                                                </Border>
                                            </Grid>

                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="19"
                                                Text="{Binding Destino}"
                                                TextColor="#222222" />

                                            <Label
                                                FontSize="14"
                                                Text="{Binding Veiculo}"
                                                TextColor="#666666" />

                                            <Button
                                                BackgroundColor="#2357C6"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=VerDetalheViagemCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver detalhes da viagem"
                                                TextColor="White" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!--  AÇÕES PRINCIPAIS  -->
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Ações principais"
                        TextColor="#1B1B1B" />

                    <CollectionView ItemsSource="{Binding AtalhosPrincipais}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:QuickAccessItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">

                                    <Grid
                                        ColumnDefinitions="56,*,20"
                                        ColumnSpacing="12"
                                        MinimumHeightRequest="82">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirAtalhoCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="28"
                                            HorizontalOptions="Center"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="28" />

                                        <VerticalStackLayout
                                            Grid.Column="1"
                                            Spacing="4"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="17"
                                                Text="{Binding Titulo}"
                                                TextColor="#1B1B1B" />

                                            <Label
                                                FontSize="13"
                                                LineBreakMode="WordWrap"
                                                Text="{Binding Descricao}"
                                                TextColor="#666666" />
                                        </VerticalStackLayout>

                                        <Label
                                            Grid.Column="2"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="›"
                                            TextColor="#9AA3B2"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!--  CONSULTA DA VIAGEM  -->
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Consulta da viagem"
                        TextColor="#1B1B1B" />

                    <CollectionView ItemsSource="{Binding AtalhosConsulta}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:QuickAccessItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">

                                    <Grid
                                        ColumnDefinitions="56,*,20"
                                        ColumnSpacing="12"
                                        MinimumHeightRequest="82">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirAtalhoCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="28"
                                            HorizontalOptions="Center"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="28" />

                                        <VerticalStackLayout
                                            Grid.Column="1"
                                            Spacing="4"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="17"
                                                Text="{Binding Titulo}"
                                                TextColor="#1B1B1B" />

                                            <Label
                                                FontSize="13"
                                                LineBreakMode="WordWrap"
                                                Text="{Binding Descricao}"
                                                TextColor="#666666" />
                                        </VerticalStackLayout>

                                        <Label
                                            Grid.Column="2"
                                            FontSize="22"
                                            HorizontalTextAlignment="Center"
                                            Text="›"
                                            TextColor="#9AA3B2"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!--  ALERTAS OPERACIONAIS  -->
                    <Border
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Image
                                HeightRequest="20"
                                Source="bell_pin_icon.svg"
                                VerticalOptions="Start"
                                WidthRequest="20" />

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    Text="Alertas operacionais"
                                    TextColor="#1B1B1B" />
                                <Label
                                    FontSize="13"
                                    Text="{Binding ResumoAlertas}"
                                    TextColor="#666666" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!--  BOTTOM BAR  -->
            <Border
                Grid.Row="2"
                Padding="10,8,10,10"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 26,26,0,0"
                StrokeThickness="0">
                <Grid ColumnDefinitions="*,*,*,*,*">
                    <VerticalStackLayout
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrInicioCommand}"
                            HeightRequest="24"
                            Source="home_icon.svg"
                            WidthRequest="24" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="Início"
                            TextColor="#F29A2E" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="1"
                        HorizontalOptions="Center"
                        Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrViagensCommand}"
                            HeightRequest="24"
                            Source="clipboard_check_icon.svg"
                            WidthRequest="24" />
                        <Label
                            FontSize="11"
                            Text="Viagens"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrMapaCommand}"
                            HeightRequest="24"
                            Source="trip_icon.svg"
                            WidthRequest="24" />
                        <Label
                            FontSize="11"
                            Text="Mapa"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="3"
                        HorizontalOptions="Center"
                        Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrAlertasCommand}"
                            HeightRequest="24"
                            Source="bell_icon.svg"
                            WidthRequest="24" />
                        <Label
                            FontSize="11"
                            Text="Alertas"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="4"
                        HorizontalOptions="Center"
                        Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrConfigCommand}"
                            HeightRequest="24"
                            Source="config_icon.svg"
                            WidthRequest="24" />
                        <Label
                            FontSize="11"
                            Text="Config"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!--  OVERLAY  -->
        <Grid BackgroundColor="#66000000" IsVisible="{Binding MenuAberto}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCommand}" />
            </Grid.GestureRecognizers>
        </Grid>

        <!--  MENU LATERAL  -->
        <Grid
            HorizontalOptions="Start"
            IsVisible="{Binding MenuAberto}"
            WidthRequest="300">

            <Border
                BackgroundColor="#F4F5FA"
                StrokeShape="RoundRectangle 0,0,18,18"
                StrokeThickness="0">

                <Grid RowDefinitions="Auto,*">
                    <Grid Padding="16,26,16,18" BackgroundColor="#2357C6">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                Text="{Binding NomeMotorista}"
                                TextColor="White" />
                            <Label
                                FontSize="13"
                                Text="{Binding EmailMotorista}"
                                TextColor="#DCE6FF" />
                        </VerticalStackLayout>
                    </Grid>

                    <CollectionView
                        Grid.Row="1"
                        Margin="12,10,12,18"
                        ItemsSource="{Binding ItensMenu}"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SideMenuItem">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0">

                                    <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirItemMenuCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            HeightRequest="20"
                                            Source="{Binding Icone}"
                                            WidthRequest="20" />

                                        <Label
                                            Grid.Column="1"
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding Titulo}"
                                            TextColor="#1B1B1B"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>