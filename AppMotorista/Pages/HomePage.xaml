<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:HomePageViewModel"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!--  CONTEÚDO PRINCIPAL  -->
        <Grid RowDefinitions="Auto,*">

            <!--  TOPO AZUL  -->
            <Grid
                Grid.Row="0"
                Padding="8,0,8,0"
                BackgroundColor="#2357C6"
                ColumnDefinitions="40,*,40"
                HeightRequest="46">

                <ImageButton
                    Grid.Column="0"
                    Padding="4"
                    BackgroundColor="Transparent"
                    Command="{Binding AlternarMenuCommand}"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    Source="menuhamburguer_icon.svg"
                    VerticalOptions="Center"
                    WidthRequest="24" />

                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalTextAlignment="Start"
                    Text="TFD Motorista"
                    TextColor="White"
                    VerticalTextAlignment="Center" />

                <ImageButton
                    Grid.Column="2"
                    Padding="4"
                    BackgroundColor="Transparent"
                    Command="{Binding AbrirQrCodeCommand}"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    Source="qrcode_icon.svg"
                    VerticalOptions="Center"
                    WidthRequest="24" />
            </Grid>

            <!--  CONTEÚDO  -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="14,16,14,28" Spacing="16">

                    <!--  SAUDAÇÃO  -->
                    <VerticalStackLayout Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding SaudacaoMotorista}"
                            TextColor="#111827" />

                        <Label
                            FontSize="12"
                            Text="Pronto para iniciar sua rota?"
                            TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <!--  RESUMO DO DIA  -->
                    <Border
                        Padding="16,13"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow
                                Brush="#14000000"
                                Opacity="0.14"
                                Radius="10"
                                Offset="0,4" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="10">

                            <Label
                                CharacterSpacing="1"
                                FontAttributes="Bold"
                                FontSize="9"
                                Text="RESUMO DO DIA"
                                TextColor="#6B7280" />

                            <Grid ColumnDefinitions="*,*,*">

                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="21"
                                        Text="{Binding TotalViagens}"
                                        TextColor="#2357C6" />
                                    <Label
                                        FontSize="10"
                                        Text="Viagens"
                                        TextColor="#6B7280" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="21"
                                        Text="{Binding TotalPassageiros}"
                                        TextColor="#2357C6" />
                                    <Label
                                        FontSize="10"
                                        Text="Passageiros"
                                        TextColor="#6B7280" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" Spacing="1">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="21"
                                        Text="{Binding TotalAlertas}"
                                        TextColor="#E53935" />
                                    <Label
                                        FontSize="10"
                                        Text="Alertas"
                                        TextColor="#6B7280" />
                                </VerticalStackLayout>

                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!--  VIAGENS DO DIA  -->
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="Viagens do dia"
                                TextColor="#111827" />

                            <Label
                                Grid.Column="1"
                                FontAttributes="Bold"
                                FontSize="10"
                                Text="Ver todas"
                                TextColor="#2357C6"
                                VerticalTextAlignment="Center" />
                        </Grid>

                        <dx:DXCollectionView
                            HeightRequest="170"
                            IsScrollBarVisible="False"
                            ItemSize="205"
                            ItemSpacing="12"
                            ItemsSource="{Binding ViagensDoDia}"
                            Orientation="Horizontal"
                            SelectionMode="None">

                            <dx:DXCollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TripSummaryItem">

                                    <Border
                                        Padding="13"
                                        BackgroundColor="White"
                                        StrokeThickness="0">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <Border.Shadow>
                                            <Shadow
                                                Brush="#12000000"
                                                Opacity="0.12"
                                                Radius="8"
                                                Offset="0,4" />
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="*,Auto">

                                                <Border
                                                    Grid.Column="0"
                                                    Padding="8,3"
                                                    BackgroundColor="#EEF3FF"
                                                    HorizontalOptions="Start"
                                                    StrokeThickness="0">

                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>

                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="8"
                                                        HorizontalTextAlignment="Center"
                                                        Text="{Binding Status}"
                                                        TextColor="#2357C6" />
                                                </Border>

                                                <Label
                                                    Grid.Column="1"
                                                    FontAttributes="Bold"
                                                    FontSize="11"
                                                    Text="{Binding Horario}"
                                                    TextColor="#2357C6"
                                                    VerticalTextAlignment="Center" />
                                            </Grid>

                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                LineBreakMode="TailTruncation"
                                                MaxLines="1"
                                                Text="{Binding Destino}"
                                                TextColor="#111827" />

                                            <VerticalStackLayout Spacing="4">

                                                <HorizontalStackLayout Spacing="5">
                                                    <Image
                                                        HeightRequest="11"
                                                        Source="fleet_icon.svg"
                                                        VerticalOptions="Center"
                                                        WidthRequest="11" />

                                                    <Label
                                                        FontSize="10"
                                                        LineBreakMode="TailTruncation"
                                                        MaxLines="1"
                                                        Text="{Binding Veiculo}"
                                                        TextColor="#374151" />
                                                </HorizontalStackLayout>

                                                <HorizontalStackLayout Spacing="5">
                                                    <Image
                                                        HeightRequest="11"
                                                        Source="tasklist_icon.svg"
                                                        VerticalOptions="Center"
                                                        WidthRequest="11" />

                                                    <Label
                                                        FontSize="10"
                                                        LineBreakMode="TailTruncation"
                                                        MaxLines="1"
                                                        Text="{Binding ResumoPassageiros}"
                                                        TextColor="#374151" />
                                                </HorizontalStackLayout>

                                            </VerticalStackLayout>

                                            <dx:DXButton
                                                BackgroundColor="#2357C6"
                                                ButtonType="Accent"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=VerDetalheViagemCommand}"
                                                CommandParameter="{Binding .}"
                                                Content="Ver detalhes da viagem"
                                                CornerRadius="8"
                                                FontAttributes="Bold"
                                                FontSize="10"
                                                HeightRequest="38"
                                                TextColor="White" />

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </dx:DXCollectionView.ItemTemplate>
                        </dx:DXCollectionView>
                    </VerticalStackLayout>

                    <!--  AÇÕES PRINCIPAIS  -->
                    <VerticalStackLayout Spacing="10">

                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Ações principais"
                            TextColor="#111827" />

                        <CollectionView ItemsSource="{Binding AtalhosPrincipais}" SelectionMode="None">

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout
                                    HorizontalItemSpacing="10"
                                    Orientation="Vertical"
                                    Span="3"
                                    VerticalItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:QuickAccessItem">

                                    <Border
                                        Padding="8"
                                        BackgroundColor="White"
                                        HeightRequest="72"
                                        StrokeThickness="0">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <Border.Shadow>
                                            <Shadow
                                                Brush="#10000000"
                                                Opacity="0.12"
                                                Radius="8"
                                                Offset="0,3" />
                                        </Border.Shadow>

                                        <Grid>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirAtalhoCommand}" CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>

                                            <VerticalStackLayout
                                                HorizontalOptions="Center"
                                                Spacing="6"
                                                VerticalOptions="Center">

                                                <Border
                                                    BackgroundColor="#EEF3FF"
                                                    HeightRequest="27"
                                                    HorizontalOptions="Center"
                                                    StrokeThickness="0"
                                                    WidthRequest="27">

                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="13" />
                                                    </Border.StrokeShape>

                                                    <Image
                                                        HeightRequest="15"
                                                        HorizontalOptions="Center"
                                                        Source="{Binding Icone}"
                                                        VerticalOptions="Center"
                                                        WidthRequest="15" />
                                                </Border>

                                                <Label
                                                    FontSize="9"
                                                    HorizontalTextAlignment="Center"
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="2"
                                                    Text="{Binding Titulo}"
                                                    TextColor="#111827" />

                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!--  ALERTA OPERACIONAL  -->
                    <Border
                        Padding="14"
                        BackgroundColor="#FFF7F7"
                        Stroke="#F2A4A4"
                        StrokeDashArray="4,3"
                        StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                            <Image
                                Grid.Column="0"
                                HeightRequest="18"
                                Source="bell_pin_icon.svg"
                                VerticalOptions="Start"
                                WidthRequest="18" />

                            <VerticalStackLayout Grid.Column="1" Spacing="4">

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="Alerta Operacional"
                                    TextColor="#D32F2F" />

                                <Label
                                    FontSize="11"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding ResumoAlertas}"
                                    TextColor="#C62828" />

                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!--  OVERLAY ESCURO  -->
        <Grid BackgroundColor="#66000000" IsVisible="{Binding MenuAberto}">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCommand}" />
            </Grid.GestureRecognizers>
        </Grid>

        <!--  MENU LATERAL  -->
        <Grid
            BackgroundColor="White"
            HorizontalOptions="Start"
            IsVisible="{Binding MenuAberto}"
            WidthRequest="272">

            <Grid RowDefinitions="Auto,*,Auto">

                <!--  PERFIL  -->
                <VerticalStackLayout
                    Grid.Row="0"
                    Padding="18,28,18,20"
                    Spacing="10">

                    <Border
                        BackgroundColor="#EAF1FF"
                        HeightRequest="52"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        WidthRequest="52">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="JS"
                            TextColor="#2357C6"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="{Binding NomeMotorista}"
                            TextColor="#111827" />

                        <Label
                            FontSize="10"
                            Text="{Binding IdMotorista}"
                            TextColor="#6B7280" />

                        <Border
                            Padding="6,2"
                            BackgroundColor="#EEF3FF"
                            HorizontalOptions="Start"
                            StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5" />
                            </Border.StrokeShape>

                            <Label
                                FontAttributes="Bold"
                                FontSize="8"
                                Text="MOTORISTA TFD"
                                TextColor="#2357C6" />
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!--  ITENS  -->
                <CollectionView
                    Grid.Row="1"
                    Margin="0,0,0,0"
                    ItemsSource="{Binding ItensMenu}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SideMenuItem">

                            <Grid Padding="12,2">

                                <Border
                                    Padding="12,10"
                                    BackgroundColor="{Binding CorFundo}"
                                    StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="22,*" ColumnSpacing="10">

                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirItemMenuCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="16"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="16" />

                                        <Label
                                            Grid.Column="1"
                                            FontSize="11"
                                            Text="{Binding Titulo}"
                                            TextColor="{Binding CorTexto}"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--  SAIR  -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Padding="18,0,18,28"
                    Spacing="16">

                    <BoxView HeightRequest="1" Color="#F0F0F0" />

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SairCommand}" />
                        </Grid.GestureRecognizers>

                        <Image
                            Grid.Column="0"
                            HeightRequest="16"
                            Source="power_icon.svg"
                            VerticalOptions="Center"
                            WidthRequest="16" />

                        <Label
                            Grid.Column="1"
                            FontSize="11"
                            Text="Sair"
                            TextColor="#E53935"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>