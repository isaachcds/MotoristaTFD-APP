<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:HomePageViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid>
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- TOPO -->
            <Grid
                Grid.Row="0"
                Padding="18,20,18,16"
                BackgroundColor="#2357C6"
                RowDefinitions="Auto,Auto">

                <Grid ColumnDefinitions="48,*,48">
                    <ImageButton
                        Grid.Column="0"
                        BackgroundColor="Transparent"
                        Command="{Binding AlternarMenuCommand}"
                        HeightRequest="28"
                        Source="menuhamburguer_icon.svg"
                        WidthRequest="28" />

                    <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        FontSize="24"
                        HorizontalTextAlignment="Center"
                        Text="Motorista"
                        TextColor="White"
                        VerticalTextAlignment="Center" />

                    <ImageButton
                        Grid.Column="2"
                        BackgroundColor="Transparent"
                        Command="{Binding AbrirQrCodeCommand}"
                        HeightRequest="28"
                        Source="qrcode_icon.svg"
                        WidthRequest="28" />
                </Grid>

                <VerticalStackLayout
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="Resumo do dia"
                        TextColor="White" />
                    <Label
                        FontSize="13"
                        Text="{Binding ResumoDia}"
                        TextColor="#DCE6FF" />
                </VerticalStackLayout>
            </Grid>

            <!-- CONTEÚDO -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                    <!-- Card destaque -->
                    <Border
                        Padding="16"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout Spacing="10">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="{Binding ProximaViagem.Titulo}"
                                TextColor="#1B1B1B" />

                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        FontSize="14"
                                        Text="{Binding ProximaViagem.Data}"
                                        TextColor="#666666" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="20"
                                        Text="{Binding ProximaViagem.Horario}"
                                        TextColor="#2357C6" />
                                </VerticalStackLayout>

                                <Border
                                    Grid.Column="1"
                                    Padding="10,4"
                                    BackgroundColor="#E8F6EC"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        Text="{Binding ProximaViagem.Status}"
                                        TextColor="#239B56" />
                                </Border>
                            </Grid>

                            <Label
                                FontAttributes="Bold"
                                FontSize="17"
                                Text="{Binding ProximaViagem.Destino}"
                                TextColor="#222222" />

                            <Label
                                FontSize="14"
                                Text="{Binding ProximaViagem.Veiculo}"
                                TextColor="#555555" />
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Acessos rápidos"
                        TextColor="#1B1B1B" />

                    <CollectionView
                        ItemsSource="{Binding Atalhos}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout
                                Orientation="Vertical"
                                ItemSpacing="14" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:QuickAccessItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20">

                                    <Grid ColumnDefinitions="56,*,20" ColumnSpacing="12">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirAtalhoCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="40"
                                            HorizontalOptions="Center"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="40" />

                                        <VerticalStackLayout
                                            Grid.Column="1"
                                            Spacing="4"
                                            VerticalOptions="Center">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="17"
                                                Text="{Binding Titulo}"
                                                TextColor="#1B1B1B" />

                                            <Label
                                                FontSize="13"
                                                LineBreakMode="WordWrap"
                                                Text="{Binding Descricao}"
                                                TextColor="#555555" />
                                        </VerticalStackLayout>

                                        <Label
                                            Grid.Column="2"
                                            FontSize="24"
                                            HorizontalTextAlignment="Center"
                                            Text="›"
                                            TextColor="#8B93A6"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- BOTTOM BAR -->
            <Border
                Grid.Row="2"
                Padding="10,10,10,12"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 26,26,0,0">
                <Grid ColumnDefinitions="*,*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrInicioCommand}"
                            HeightRequest="28"
                            Source="menuhamburguer_icon.svg"
                            WidthRequest="28" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="Início"
                            TextColor="#F29A2E" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrViagensCommand}"
                            HeightRequest="28"
                            Source="qrcode_icon.svg"
                            WidthRequest="28" />
                        <Label
                            FontSize="12"
                            Text="Viagens"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrAlertasCommand}"
                            HeightRequest="28"
                            Source="bell_icon.svg"
                            WidthRequest="28" />
                        <Label
                            FontSize="12"
                            Text="Alertas"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                        <ImageButton
                            BackgroundColor="Transparent"
                            Command="{Binding IrConfigCommand}"
                            HeightRequest="28"
                            Source="config_icon.svg"
                            WidthRequest="28" />
                        <Label
                            FontSize="12"
                            Text="Config"
                            TextColor="#3A3F4B" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- OVERLAY -->
        <Grid
            BackgroundColor="#66000000"
            IsVisible="{Binding MenuAberto}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCommand}" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- MENU LATERAL -->
        <Grid
            HorizontalOptions="Start"
            IsVisible="{Binding MenuAberto}"
            WidthRequest="300">

            <Border
                BackgroundColor="#F4F5FA"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,18,18">

                <Grid RowDefinitions="Auto,*">
                    <Grid
                        Padding="16,26,16,18"
                        BackgroundColor="#2357C6">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                Text="{Binding NomeMotorista}"
                                TextColor="White" />
                            <Label
                                FontSize="13"
                                Text="{Binding EmailMotorista}"
                                TextColor="#DCE6FF" />
                        </VerticalStackLayout>
                    </Grid>

                    <CollectionView
                        Grid.Row="1"
                        ItemsSource="{Binding ItensMenu}"
                        SelectionMode="None"
                        Margin="12,10,12,18">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SideMenuItem">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                    <Grid ColumnDefinitions="36,*">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomePageViewModel}}, Path=AbrirItemMenuCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="22"
                                            Source="{Binding Icone}"
                                            WidthRequest="22" />

                                        <Label
                                            Grid.Column="1"
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding Titulo}"
                                            TextColor="#1B1B1B"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>