<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.DetalheViagemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:DetalheViagemViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            ColumnDefinitions="48,*"
            RowDefinitions="Auto,Auto">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding CodigoViagem}"
                TextColor="#DCE6FF" />
        </Grid>

        <!--  CONTEÚDO  -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <!--  RESUMO  -->
                <Border
                    Padding="18"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 22"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontSize="13"
                                    Text="{Binding Data}"
                                    TextColor="#777777" />

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="26"
                                    Text="{Binding Horario}"
                                    TextColor="#2357C6" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10,5"
                                BackgroundColor="{Binding StatusCorFundo}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                VerticalOptions="Start">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding Status}"
                                    TextColor="{Binding StatusCorTexto}" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="19"
                                Text="{Binding Destino}"
                                TextColor="#1B1B1B" />
                            <Label
                                FontSize="14"
                                Text="{Binding Observacoes}"
                                TextColor="#666666" />
                        </VerticalStackLayout>

                        <Border
                            Padding="10,6"
                            BackgroundColor="#EEF4FF"
                            HorizontalOptions="Start"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0">
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="{Binding OcupacaoResumo}"
                                TextColor="#2357C6" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!--  AVISO OPERACIONAL  -->
                <Border
                    Padding="14"
                    BackgroundColor="#FFF4E5"
                    IsVisible="{Binding ExibirAvisoVeiculoProprio}"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="!"
                            TextColor="#B96A00"
                            VerticalTextAlignment="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding AvisoOperacionalTitulo}"
                                TextColor="#B96A00" />
                            <Label
                                FontSize="13"
                                Text="{Binding AvisoOperacionalDescricao}"
                                TextColor="#7A5A00" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!--  INFORMAÇÕES DA ROTA  -->
                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="14">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Informações da rota"
                            TextColor="#1B1B1B" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Origem"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding Origem}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Destino"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding Destino}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="12"
                                Text="Equipe de apoio"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding EquipeApoio}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!--  VEÍCULO  -->
                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Veículo"
                                TextColor="#1B1B1B" />

                            <Border
                                Grid.Column="1"
                                Padding="10,5"
                                BackgroundColor="#E9F7EF"
                                IsVisible="{Binding VeiculoProprio}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding TextoVeiculoProprio}"
                                    TextColor="#239B56" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Modelo"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding ModeloVeiculo}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Placa"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding PlacaVeiculo}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Capacidade"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding CapacidadeVeiculo}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Combustível"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding TipoCombustivel}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="12"
                                Text="Resumo do veículo"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding Veiculo}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!--  MOTORISTA  -->
                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="14">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Motorista"
                            TextColor="#1B1B1B" />

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="12"
                                Text="Nome"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding Motorista}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="CNH"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding CnhMotorista}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label
                                    FontSize="12"
                                    Text="Contato"
                                    TextColor="#2357C6" />
                                <Label
                                    FontSize="14"
                                    Text="{Binding ContatoMotorista}"
                                    TextColor="#1B1B1B" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!--  PONTOS DA ROTA  -->
                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Pontos da rota"
                            TextColor="#1B1B1B" />

                        <CollectionView ItemsSource="{Binding PontosDaRota}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Label
                                            FontSize="14"
                                            Text="●"
                                            TextColor="#2357C6"
                                            VerticalTextAlignment="Start" />
                                        <Label
                                            Grid.Column="1"
                                            FontSize="14"
                                            Text="{Binding .}"
                                            TextColor="#1B1B1B" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!--  PASSAGEIROS  -->
                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="Passageiros"
                                TextColor="#1B1B1B" />

                            <Label
                                Grid.Column="1"
                                FontSize="12"
                                Text="{Binding ResumoPassageiros}"
                                TextColor="#666666"
                                VerticalTextAlignment="Center" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding Passageiros}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Border
                                        Padding="12"
                                        BackgroundColor="#F8F9FC"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="0">
                                        <Label
                                            FontSize="14"
                                            Text="{Binding .}"
                                            TextColor="#1B1B1B" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!--  AÇÕES  -->
                <VerticalStackLayout Spacing="12">
                    <Button
                        BackgroundColor="#2357C6"
                        Command="{Binding IniciarViagemCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Iniciar viagem"
                        TextColor="White" />

                    <Button
                        BackgroundColor="#F3F5FB"
                        Command="{Binding AbrirMapaCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Ver no mapa"
                        TextColor="#2357C6" />

                    <Button
                        BackgroundColor="#F3F5FB"
                        Command="{Binding AbrirEmbarqueCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Embarque"
                        TextColor="#2357C6" />

                    <Button
                        BackgroundColor="#F3F5FB"
                        Command="{Binding RegistrarOcorrenciaCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Registrar ocorrência"
                        TextColor="#2357C6" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>