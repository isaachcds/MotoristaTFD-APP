<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.OcorrenciaFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:OcorrenciaFormViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding CodigoViagem}"
                TextColor="#DCE6FF" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Resumo da viagem"
                            TextColor="#1B1B1B" />

                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="12" Text="Destino" TextColor="#2357C6" />
                            <Label FontSize="14" Text="{Binding Destino}" TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="14">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Dados da ocorrência"
                            TextColor="#1B1B1B" />

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="12" Text="Tipo" TextColor="#2357C6" />
                            <Entry
                                BackgroundColor="#F8F9FC"
                                Text="{Binding TipoOcorrencia}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="12" Text="Prioridade" TextColor="#2357C6" />
                            <Entry
                                BackgroundColor="#F8F9FC"
                                Text="{Binding Prioridade}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="12" Text="Local" TextColor="#2357C6" />
                            <Entry
                                BackgroundColor="#F8F9FC"
                                Text="{Binding LocalOcorrencia}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="12" Text="Descrição" TextColor="#2357C6" />
                            <Editor
                                AutoSize="TextChanges"
                                BackgroundColor="#F8F9FC"
                                HeightRequest="110"
                                Text="{Binding Descricao}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="12" Text="Observações" TextColor="#2357C6" />
                            <Editor
                                AutoSize="TextChanges"
                                BackgroundColor="#F8F9FC"
                                HeightRequest="100"
                                Text="{Binding Observacoes}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Button
                        BackgroundColor="#2357C6"
                        Command="{Binding SalvarCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Salvar ocorrência"
                        TextColor="White" />

                    <Button
                        BackgroundColor="#F3F5FB"
                        Command="{Binding CancelarCommand}"
                        CornerRadius="16"
                        HeightRequest="48"
                        Text="Cancelar"
                        TextColor="#2357C6" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>