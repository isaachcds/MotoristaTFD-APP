<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:ConfigViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="Preferências do motorista"
                TextColor="#DCE6FF" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="6">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding NomeMotorista}"
                            TextColor="#1B1B1B" />
                        <Label
                            FontSize="13"
                            Text="{Binding EmailMotorista}"
                            TextColor="#666666" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="14">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Preferências"
                            TextColor="#1B1B1B" />

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label FontSize="15" Text="Notificações" TextColor="#1B1B1B" />
                                <Label FontSize="12" Text="Receber alertas operacionais e ocorrências." TextColor="#777777" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding NotificacoesAtivas}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label FontSize="15" Text="Modo silencioso" TextColor="#1B1B1B" />
                                <Label FontSize="12" Text="Reduz sons e interrupções no uso do app." TextColor="#777777" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding ModoSilencioso}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label FontSize="15" Text="Confirmar saída" TextColor="#1B1B1B" />
                                <Label FontSize="12" Text="Pedir confirmação antes de encerrar sessão." TextColor="#777777" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding ConfirmarSaida}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Sistema"
                            TextColor="#1B1B1B" />

                        <Button
                            BackgroundColor="#F3F5FB"
                            Command="{Binding AbrirSuporteCommand}"
                            CornerRadius="14"
                            HeightRequest="42"
                            Text="Abrir suporte"
                            TextColor="#2357C6" />

                        <Button
                            BackgroundColor="#F3F5FB"
                            Command="{Binding SobreSistemaCommand}"
                            CornerRadius="14"
                            HeightRequest="42"
                            Text="Sobre o sistema"
                            TextColor="#2357C6" />

                        <Label
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            Text="{Binding VersaoApp}"
                            TextColor="#888888" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>