<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.SuportePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:SuporteViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding Resumo}"
                TextColor="#DCE6FF" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Canais de atendimento"
                            TextColor="#1B1B1B" />

                        <Button
                            BackgroundColor="#F3F5FB"
                            Command="{Binding AbrirWhatsappCommand}"
                            CornerRadius="14"
                            HeightRequest="42"
                            Text="WhatsApp do suporte"
                            TextColor="#2357C6" />

                        <Button
                            BackgroundColor="#F3F5FB"
                            Command="{Binding LigarCommand}"
                            CornerRadius="14"
                            HeightRequest="42"
                            Text="Ligar para suporte"
                            TextColor="#2357C6" />

                        <Button
                            BackgroundColor="#F3F5FB"
                            Command="{Binding EnviarEmailCommand}"
                            CornerRadius="14"
                            HeightRequest="42"
                            Text="Enviar e-mail"
                            TextColor="#2357C6" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="10">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Dúvidas rápidas"
                            TextColor="#1B1B1B" />

                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="• Como iniciar uma viagem?"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="13"
                            Text="Acesse Minhas Viagens, abra o detalhe da viagem e toque em Iniciar viagem."
                            TextColor="#666666" />

                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="• Como registrar uma ocorrência?"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="13"
                            Text="Você pode abrir Alertas e Ocorrências ou registrar diretamente no detalhe da viagem."
                            TextColor="#666666" />

                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="• Como confirmar o embarque?"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="13"
                            Text="Use a tela de Embarque para marcar passageiros embarcados ou ausentes."
                            TextColor="#666666" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>