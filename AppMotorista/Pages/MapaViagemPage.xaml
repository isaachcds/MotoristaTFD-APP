<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.MapaViagemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:MapaViagemViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOPO -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding ResumoMapa}"
                TextColor="#DCE6FF" />
        </Grid>

        <!-- MAPA -->
        <maps:Map
            x:Name="MapaView"
            Grid.Row="1"
            IsShowingUser="False"
            MapType="Street"
            VerticalOptions="FillAndExpand" />

        <!-- CARD INFERIOR -->
        <Border
            Grid.Row="2"
            Margin="14,0,14,14"
            Padding="16"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 22"
            VerticalOptions="End">

            <VerticalStackLayout Spacing="12">
                <Label
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Resumo da rota"
                    TextColor="#1B1B1B" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontSize="12"
                            Text="Origem"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="14"
                            Text="{Binding Origem}"
                            TextColor="#1B1B1B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4">
                        <Label
                            FontSize="12"
                            Text="Destino"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="14"
                            Text="{Binding Destino}"
                            TextColor="#1B1B1B" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontSize="12"
                            Text="Próximo ponto"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="14"
                            Text="{Binding ProximoPonto}"
                            TextColor="#1B1B1B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4">
                        <Label
                            FontSize="12"
                            Text="Status"
                            TextColor="#2357C6" />
                        <Label
                            FontSize="14"
                            Text="{Binding StatusRota}"
                            TextColor="#1B1B1B" />
                    </VerticalStackLayout>
                </Grid>

                <Button
                    BackgroundColor="#2357C6"
                    Command="{Binding AbrirMapaExternoCommand}"
                    CornerRadius="16"
                    HeightRequest="46"
                    Text="Abrir no app de mapas"
                    TextColor="White" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>