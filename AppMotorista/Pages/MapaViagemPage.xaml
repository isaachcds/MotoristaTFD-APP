<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.MapaViagemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:MapaViagemViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto">

            <!--<ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />-->

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="{Binding TituloPagina}"
                TextColor="White" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding ResumoMapa}"
                TextColor="#DCE6FF" />
        </Grid>

        <!--  CONTEÚDO  -->
        <Grid Grid.Row="1">

            <!--  MAPA REAL  -->
            <maps:Map
                x:Name="MapaView"
                HorizontalOptions="FillAndExpand"
                IsShowingUser="False"
                VerticalOptions="FillAndExpand" />

            <!--  CARD SUPERIOR  -->
            <Border
                Margin="18,18,18,0"
                Padding="14"
                BackgroundColor="White"
                HorizontalOptions="Fill"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Start">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding StatusRota}"
                            TextColor="#1B1B1B" />
                        <Label
                            FontSize="13"
                            Text="Acompanhe a rota prevista da viagem"
                            TextColor="#666666" />
                    </VerticalStackLayout>

                    <Border
                        Grid.Column="1"
                        Padding="10,6"
                        BackgroundColor="#E8F1FF"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="Rota ativa"
                            TextColor="#2357C6" />
                    </Border>
                </Grid>
            </Border>

            <!--  CARD INFERIOR  -->
            <Border
                Margin="18,0,18,24"
                Padding="16"
                BackgroundColor="White"
                HorizontalOptions="Fill"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="0"
                VerticalOptions="End">

                <VerticalStackLayout Spacing="14">

                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Resumo da rota"
                        TextColor="#1B1B1B" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label
                            FontSize="14"
                            Text="●"
                            TextColor="#2E7D32"
                            VerticalTextAlignment="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label
                                FontSize="12"
                                Text="Origem"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding Origem}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label
                            FontSize="14"
                            Text="●"
                            TextColor="#FB8C00"
                            VerticalTextAlignment="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label
                                FontSize="12"
                                Text="Próximo ponto"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding ProximoPonto}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label
                            FontSize="14"
                            Text="●"
                            TextColor="#C62828"
                            VerticalTextAlignment="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label
                                FontSize="12"
                                Text="Destino"
                                TextColor="#2357C6" />
                            <Label
                                FontSize="14"
                                Text="{Binding Destino}"
                                TextColor="#1B1B1B" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Grid.Column="0"
                            BackgroundColor="#F3F5FB"
                            Command="{Binding VoltarCommand}"
                            CornerRadius="16"
                            HeightRequest="46"
                            Text="Voltar"
                            TextColor="#2357C6" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="#2357C6"
                            Command="{Binding AbrirMapaExternoCommand}"
                            CornerRadius="16"
                            HeightRequest="46"
                            Text="Abrir navegação"
                            TextColor="White" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>